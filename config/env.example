NODE_ENV=development
PORT=3000

# Database
# Use PostgreSQL (production) or SQLite (local development)
# For PostgreSQL, set DB_HOST, DB_USER, DB_PASSWORD
# For SQLite, set DB_PATH (or leave unset for default: data/stoic-shop.db)

# PostgreSQL (production)
# DB_HOST=stoic-fitness-pg.c7c9btnoxixy.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=stoicapp
# DB_PASSWORD=your-database-password
# DB_SSL=true  # Set to 'false' to disable SSL

# SQLite (local development)
DB_PATH=data/stoic-shop.db

# JWT configuration
JWT_SECRET=replace-with-secure-random-string
JWT_EXPIRES_IN=30d

# Stripe configuration (test by default)
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
# For local dev: npm run dev captures this automatically from stripe listen
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_me
# Billing mode: one_time | stripe_subscriptions
BILLING_MODE=one_time
# Stripe Price IDs (used if BILLING_MODE=stripe_subscriptions)
# New tier-based naming (recommended)
STRIPE_PRICE_TIER_TWO=price_tier_two_test
STRIPE_PRICE_TIER_THREE=price_tier_three_test
STRIPE_PRICE_TIER_FOUR=price_tier_four_test
# Legacy naming (still syes, upported for backward compatibility)
# STRIPE_PRICE_DAILY=price_daily_test
# STRIPE_PRICE_WEEKLY=price_weekly_test
# STRIPE_PRICE_MONTHLY=price_monthly_test

# Google OAuth / Slides integration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=refresh-token-with-drive-scope
# Dev redirect for localhost; set production in deployment env vars
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Production values (set in ECS env or Parameter Store)
# GOOGLE_CLIENT_ID_PROD=
# GOOGLE_CLIENT_SECRET_PROD=
# GOOGLE_REDIRECT_URI_PROD=https://app.stoic-fit.com/auth/google/callback

# CORS origins (comma-separated). Localhost allowed by default; add prod origin(s) here.
CORS_ORIGINS=https://app.stoic-fit.com

# Background jobs (ECS uses the same names). In development, jobs stay off unless you opt in.
# Production enables these via NODE_ENV=production and/or explicit flags.
# ENABLE_SYNC_JOB=true
# ENABLE_NIGHTLY_JOB=true
# ENABLE_LEGACY_INVOICE_RENEWAL_JOB=true

# Public API base (optional)
# PUBLIC_API_BASE_URL=https://app.stoic-fit.com/api

# Sentry (optional)
# SENTRY_DSN=

